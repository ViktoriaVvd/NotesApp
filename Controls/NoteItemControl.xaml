<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="NoteApp.Controls.NoteItemControl"
    x:Name="this">
    <Border Padding="12"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12"
        BackgroundColor="#FFFFFF"
        Stroke="#E0E0E0">

        <StackLayout Spacing="6">
            <Label Text="{Binding NoteTitle, Source={x:Reference this}}"
               FontSize="18"
               FontAttributes="Bold"
               TextColor="#222"/>

            <Label Text="{Binding NoteContent, Source={x:Reference this}}"
                FontSize="15"
                TextColor="Gray"
                HorizontalOptions="Fill"
                LineBreakMode="WordWrap"/>
        </StackLayout>
    </Border>
</ContentView>