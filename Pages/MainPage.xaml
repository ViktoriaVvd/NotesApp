<ContentPage
    x:Class="NoteApp.Pages.MainPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">


    <StackLayout Padding="20" Margin="20">
        <Label Text="З поверненням!" FontSize="36" HorizontalOptions="Center"/>
        <Image Source="dotnet_bot.png" WidthRequest="200" HeightRequest="200"/>
        <Label Text="{Binding CurrentDateTime}" FontSize="24" TextColor="BlanchedAlmond" HorizontalOptions="Center"/>

        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="10">
            <Button Grid.Column="0" 
            Grid.Row="0" 
            Grid.RowSpan="2" 
            Text="Перейти до нотаток" 
            BackgroundColor="LightSkyBlue"
            Command="{Binding GoToNotesCommand}"/>

            <Button Grid.Column="1" 
            Grid.Row="0" 
            Text="Перейти до завдань"
            BackgroundColor="LightSkyBlue"
            Command="{Binding GoToTasksCommand}"/>

            <Button Grid.Column="1" 
            Grid.Row="1" 
            Text="Перевірка властивостей пристрою та мережі"
            BackgroundColor="LightSkyBlue"
            Command="{Binding GoToInfoCommand}"/>

        </Grid>
    </StackLayout>
    
</ContentPage>
