<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NoteApp.Models"
             x:Class="NoteApp.Pages.TasksPage">
    <VerticalStackLayout Spacing="10" Padding="10">
        <Label Text="Список завдань" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Tasks}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TaskItem">
                    <Border
                       Margin="0,5" 
                       Padding="15"
                       BackgroundColor="#F0F0F0">

                        <HorizontalStackLayout Spacing="15">
                            <CheckBox IsChecked="{Binding Completed}" IsEnabled="False" VerticalOptions="Center"/>

                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding Title}" 
                                   FontSize="16" 
                                   FontAttributes="Bold" 
                                   TextColor="Black" />

                                <Label Text="{Binding Id, StringFormat='ID завдання: {0}'}" 
                                   FontSize="12" 
                                   TextColor="Gray" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Завантажити дані" 
            Command="{Binding LoadDataCommand}" 
            Margin="10" />
        <Button Text="На головну" Command="{Binding GoBackCommand}" WidthRequest="150" HeightRequest="60"/>
    </VerticalStackLayout>
</ContentPage>